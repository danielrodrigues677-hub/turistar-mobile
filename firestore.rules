rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{emailId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/users/$(emailId))
        && request.resource.data.keys().hasAll(['email', 'name', 'phone', 'passwordHash']);
      allow update, delete: if false;
    }
  }
}
