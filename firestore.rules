rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function roleFromUserDoc(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        ? get(/databases/$(database)/documents/users/$(userId)).data.role
        : null;
    }

    function userEmail() {
      return request.auth.token.email == null ? '' : request.auth.token.email.lower();
    }

    function userRole() {
      return signedIn()
        ? (
            roleFromUserDoc(request.auth.uid)
            ?? (userEmail() != '' ? roleFromUserDoc(userEmail()) : null)
          )
        : null;
    }

    function isAgentOrAdmin() {
      return signedIn() && userRole() in ['agent', 'admin'];
    }

    function isOperacionalOrAdmin() {
      return signedIn() && userRole() in ['operacional', 'admin'];
    }

    function isAnyStaff() {
      return signedIn() && userRole() in ['agent', 'admin', 'operacional'];
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/users/$(userId))
        && request.resource.data.keys().hasAll(['email', 'name', 'phone', 'role', 'createdAt', 'updatedAt'])
        && request.resource.data.role == 'customer'
        && !('passwordHash' in request.resource.data);
      // Login REST (Safari): indexa perfil em users/{email} para regras de staff.
      allow create, update: if signedIn()
        && userEmail() != ''
        && userId == userEmail()
        && request.resource.data.email == userEmail()
        && request.resource.data.role in ['customer', 'agent', 'admin', 'operacional']
        && request.resource.data.keys().hasAll(['email', 'name', 'phone', 'role', 'createdAt', 'updatedAt']);
      // Espelha perfil em users/{firebaseUid} apos indexacao por e-mail.
      allow create: if isOwner(userId)
        && userId == request.auth.uid
        && userEmail() != ''
        && request.resource.data.email == userEmail()
        && request.resource.data.keys().hasAll(['email', 'name', 'phone', 'role', 'createdAt', 'updatedAt'])
        && (
          request.resource.data.role == 'customer'
          || (
            request.resource.data.role in ['agent', 'admin', 'operacional']
            && request.resource.data.role == roleFromUserDoc(userEmail())
          )
        );
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /travel_requests/{requestId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAgentOrAdmin() || isOperacionalOrAdmin());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'userId', 'userEmail', 'origin', 'destination', 'departureDate',
          'passengers', 'status', 'createdAt', 'updatedAt'
        ])
        && (request.resource.data.status == 'NEW' || request.resource.data.status == 'pending');
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAgentOrAdmin());
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAnyStaff());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'status', 'createdAt', 'updatedAt']);
      allow update: if isAgentOrAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAnyStaff());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'status', 'createdAt', 'updatedAt']);
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isOperacionalOrAdmin());
      allow delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAgentOrAdmin();
    }

    match /featured_packages/{featuredId} {
      allow read: if true;
      allow write: if isAgentOrAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAgentOrAdmin();
    }

    match /destinations/{destinationId} {
      allow read: if true;
      allow write: if isAgentOrAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAgentOrAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAnyStaff();
      allow write: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
