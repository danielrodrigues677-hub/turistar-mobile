rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /packages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /destinations/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
